# Fal.ai API key — https://fal.ai/dashboard/keys
FAL_API_KEY=your_fal_api_key_here

# Vercel Blob storage token — https://vercel.com/docs/storage/vercel-storage/vercel-blob
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# Upstash Redis — https://console.upstash.com
# Create a database → REST API → copy URL and token.
# Also available via Vercel Marketplace: vercel.com/marketplace/upstash
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# Rate limiting: generations per IP per 24-hour window (defaults shown)
DAILY_LIMIT=3
DAILY_LIMIT_PROFI=20
DAILY_LIMIT_AGENCY=100

# Dev overrides (optional)
# BYPASS_RATE_LIMIT=true        # disable rate limiting completely
# DEV_IPS=127.0.0.1,::1         # IPs that always bypass the limit
